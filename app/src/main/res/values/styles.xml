<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="CalcButtonBase" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_rowWeight">1</item>
        <item name="android:layout_gravity">fill</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">36sp</item>
        <item name="cornerRadius">16dp</item>
    </style>

    <style name="CalcButton" parent="CalcButtonBase">
        <item name="backgroundTint">@color/btn_digit</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="SciButton" parent="CalcButtonBase">
        <item name="backgroundTint">@color/btn_sci</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">26sp</item>
    </style>

    <style name="OpButton" parent="CalcButtonBase">
        <item name="backgroundTint">@color/btn_op</item>
        <item name="android:textColor">@color/color_primary</item>
        <item name="android:textSize">40sp</item>
    </style>

    <style name="AccentButton" parent="CalcButtonBase">
        <item name="backgroundTint">@color/btn_accent</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">40sp</item>
    </style>

    <style name="ClearButton" parent="CalcButtonBase">
        <item name="backgroundTint">@color/btn_clear</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">36sp</item>
    </style>
</resources>